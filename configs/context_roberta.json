{
  "experiment_name": "context_roberta",
  "backbone": "roberta-base",
  "max_length": 128,
  "dropout": 0.1,

  "context": {
    "strategy": "window",
    "k": 3,
    "strategy_kwargs": {}
  },

  "loss": {
    "name": "mse",
    "emd_n_bins": 10,
    "emd_vad_range": [1.0, 5.0],
    "mse_weight": 1.0,
    "emd_weight": 0.1
  },

  "splits": {
    "mode": "leave_one_session_out",
    "test_session": 5,
    "val_session": 4,
    "train_sessions": [1, 2, 3]
  },

  "phase1": {
    "epochs": 5,
    "lr": 3e-3,
    "freeze_encoder": true,
    "warmup_ratio": 0.1
  },
  "phase2": {
    "epochs": 15,
    "lr": 5e-6,
    "freeze_encoder": false,
    "warmup_ratio": 0.1,
    "head_lr_multiplier": 10
  },

  "batch_size": 16,
  "gradient_clip": 1.0,
  "seed": 42,
  "num_workers": 4,
  "csv_path": "data/iemocap/iemocap_merged_all.csv",
  "output_dir": "outputs/context_roberta"
}
